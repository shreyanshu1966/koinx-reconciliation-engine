# Server
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/koinx_reconciliation

# CSV data file paths (relative to project root)
USER_TRANSACTIONS_FILE=./data/user_transactions.csv
EXCHANGE_TRANSACTIONS_FILE=./data/exchange_transactions.csv

# Directory where CSV reports are saved
REPORTS_DIR=./reports

# --- Matching Tolerances ---
# Maximum allowed timestamp difference (in seconds) for a match
TIMESTAMP_TOLERANCE_SECONDS=300

# Maximum allowed quantity difference (as a percentage, e.g. 0.01 = 0.01%) for a match
QUANTITY_TOLERANCE_PCT=0.01
